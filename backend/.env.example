# ============================================================
# Excell-On Services Backend - Environment Variables (Example)
# ============================================================

# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3307
DB_NAME=ecs_db
DB_USER=root
DB_PASSWORD=your_mysql_password_here

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=24h

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173
